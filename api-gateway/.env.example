# Path to your local Hyperledger Fabric samples directory.
FABRIC_SAMPLES=/path/to/fabric-samples

# Fabric organization identifier.
ORG=org1

# Fabric channel and chaincode configuration.
CHANNEL_NAME=mychannel
CHAINCODE_NAME=incident

# Local Fabric peer connection.
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# API Gateway port.
PORT=8080
