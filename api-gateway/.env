# Path to fabric-samples (test-network will be used)
FABRIC_SAMPLES=\\wsl.localhost\Ubuntu-24.04\home\deepa\fabric-samples

# Which org identity to use (not used by current code, safe to keep)
ORG=org1

# Channel and chaincode name
CHANNEL_NAME=mychannel
CHAINCODE_NAME=incident

# Gateway target (peer endpoint for Org1)
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# API server
PORT=8080


FACE_ANALYSIS_ENABLED=true
FACE_SERVICE_URL=http://localhost:8001
FACE_VERIFY_TIMEOUT_MS=10000
FACE_ANALYSIS_CONCURRENCY=1
