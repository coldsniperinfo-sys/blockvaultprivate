# Existing BlockVault Hashledger API
VITE_BLOCKVAULT_API_URL=http://localhost:8081

# Same-origin Vite proxy to the local camera-service.
# Keep this relative path for local use and Cloudflare Quick Tunnels.
VITE_CAMERA_SERVICE_URL=/camera-stream

# The two physical Axis cameras currently in the MVP.
VITE_AXIS_CAMERA_IDS=CAM-01,CAM-02

# Used only when no network-camera configuration exists.
VITE_ENABLE_WEBCAM_FALLBACK=true

# Vite server-side proxy target. This value is not exposed to browser code.
CAMERA_SERVICE_PROXY_TARGET=http://localhost:5600

# Optional: bypass camera-service URL construction with explicit URLs.
# VITE_CAM_01_STREAM_URL=http://localhost:5600/camera/CAM-01
# VITE_CAM_02_STREAM_URL=http://localhost:5600/camera/CAM-02
# VITE_CAM_03_STREAM_URL=
